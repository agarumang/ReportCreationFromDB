<Window x:Class="ReportGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:ReportGenerator.Views"
        Title="Report Generator"
        WindowStyle="None"
        ResizeMode="CanResize"
        MinWidth="1024"
        MinHeight="640"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">
    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <local:HeaderControl Grid.Row="0"/>

        <!-- Rest of UI -->
        <Grid Grid.Row="1" Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Tables list -->
            <GroupBox Header="Tables" Grid.Column="0" Margin="0,0,0,12">
                <ListBox ItemsSource="{Binding Tables}"
                         SelectedItem="{Binding SelectedTable}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ItemContainerStyle="{StaticResource TablesListBoxItem}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>

            <!-- Spacer -->
            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

            <!-- Columns and results -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="220"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <GroupBox Header="Columns" Grid.Row="0">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal"
                                    DockPanel.Dock="Top"
                                    Margin="4,0,4,6"
                                    HorizontalAlignment="Left">
                            <Button Content="Load Data" Style="{StaticResource PrimaryButton}" Command="{Binding LoadDataCommand}" Margin="0,0,8,0" />
                            <Button Content="Select All" Style="{StaticResource SecondaryButton}" Command="{Binding SelectAllColumnsCommand}" Margin="0,0,8,0" />
                            <Button Content="Clear Selection" Style="{StaticResource SecondaryButton}" Command="{Binding ClearColumnsCommand}" Margin="0,0,16,0" />
                        </StackPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Columns}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="4"
                                                Padding="8,6"
                                                CornerRadius="10"
                                                Background="#FFFFFFFF"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1">
                                            <DockPanel LastChildFill="True">
                                                <CheckBox IsChecked="{Binding IsSelected}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,8,0"/>

                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource AccentTextBrush}"/>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </GroupBox>

                <!-- Filters (left) + Export (right) -->
                <Grid Grid.Row="1" Margin="8" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding FromDate}" SelectedDateFormat="Short" Width="130" />
                        <Border Style="{StaticResource TimePickerBox}" Margin="6,0,0,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ComboBox Style="{StaticResource TimePickerCombo}" Width="32"
                                         ItemsSource="{Binding Hours}" SelectedItem="{Binding FromHour}"
                                         ItemTemplate="{StaticResource TwoDigitNumberTemplate}" />
                                <TextBlock Text=":" Width="8" TextAlignment="Center" VerticalAlignment="Center" Margin="0" Foreground="{StaticResource MutedTextBrush}"/>
                                <ComboBox Style="{StaticResource TimePickerCombo}" Width="32"
                                         ItemsSource="{Binding Minutes}" SelectedItem="{Binding FromMinute}"
                                         ItemTemplate="{StaticResource TwoDigitNumberTemplate}" />
                            </StackPanel>
                        </Border>
                        <TextBlock Text="To:" VerticalAlignment="Center" Margin="12,0,6,0"/>
                        <DatePicker SelectedDate="{Binding ToDate}" SelectedDateFormat="Short" Width="130" />
                        <Border Style="{StaticResource TimePickerBox}" Margin="6,0,0,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ComboBox Style="{StaticResource TimePickerCombo}" Width="32"
                                         ItemsSource="{Binding Hours}" SelectedItem="{Binding ToHour}"
                                         ItemTemplate="{StaticResource TwoDigitNumberTemplate}" />
                                <TextBlock Text=":" Width="8" TextAlignment="Center" VerticalAlignment="Center" Margin="0" Foreground="{StaticResource MutedTextBrush}"/>
                                <ComboBox Style="{StaticResource TimePickerCombo}" Width="32"
                                         ItemsSource="{Binding Minutes}" SelectedItem="{Binding ToMinute}"
                                         ItemTemplate="{StaticResource TwoDigitNumberTemplate}" />
                            </StackPanel>
                        </Border>
                        <Button Content="Refresh" Style="{StaticResource PrimaryButton}" Command="{Binding LoadDataBetweenDatesCommand}" Margin="10,0,0,0" />
                    </WrapPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock Text="Export as:" VerticalAlignment="Center" Margin="8,0,4,0"/>
                        <ComboBox Width="110" ItemsSource="{Binding ExportFormats}" SelectedItem="{Binding SelectedExportFormat}" Margin="0,0,8,0" />
                        <Button Content="Export" Style="{StaticResource PrimaryButton}" Command="{Binding ExportCommand}" />
                    </StackPanel>
                </Grid>

                <DataGrid x:Name="ResultsGrid"
                          Grid.Row="2"
                          ItemsSource="{Binding Results}"
                          AutoGenerateColumns="True"
                          AutoGeneratingColumn="ResultsGrid_AutoGeneratingColumn"
                          IsReadOnly="True"
                          EnableColumnVirtualization="False"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.CanContentScroll="True"
                          ColumnWidth="160"
                          MinColumnWidth="120" />
            </Grid>
        </Grid>

        <!-- Loading overlay (blocks entire window while IsLoading=true) -->
        <Grid Grid.RowSpan="2"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
              Background="#80000000"
              IsHitTestVisible="True">
            <Border Background="#CC0B1220" CornerRadius="16" Padding="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Spinner -->
                            <Grid Width="28" Height="28" Margin="0,0,12,0">
                                <Ellipse Width="28" Height="28" Stroke="#66FFFFFF" StrokeThickness="3"/>
                                <Ellipse Width="28" Height="28" Stroke="#FFFFFFFF" StrokeThickness="3"
                                         StrokeDashArray="2 3" StrokeDashCap="Round"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                                <Grid.Triggers>
                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                                 Storyboard.TargetProperty="Angle"
                                                                 From="0" To="360"
                                                                 Duration="0:0:0.9" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Grid.Triggers>
                            </Grid>

                            <!-- Loading text with animated dots -->
                            <StackPanel VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <TextBlock Text="Loading" Foreground="White" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock x:Name="Dot1" Text="." Foreground="White" FontSize="14" FontWeight="SemiBold" Opacity="0.2"/>
                                    <TextBlock x:Name="Dot2" Text="." Foreground="White" FontSize="14" FontWeight="SemiBold" Opacity="0.2"/>
                                    <TextBlock x:Name="Dot3" Text="." Foreground="White" FontSize="14" FontWeight="SemiBold" Opacity="0.2"/>
                                </StackPanel>
                                <TextBlock Text="{Binding BusyMessage}" Foreground="#CCFFFFFF" FontSize="12" Margin="0,2,0,0"/>
                            </StackPanel>

                            <StackPanel.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="Dot1" Storyboard.TargetProperty="Opacity" From="0.2" To="1" Duration="0:0:0.25" AutoReverse="True" BeginTime="0:0:0.0" />
                                            <DoubleAnimation Storyboard.TargetName="Dot2" Storyboard.TargetProperty="Opacity" From="0.2" To="1" Duration="0:0:0.25" AutoReverse="True" BeginTime="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="Dot3" Storyboard.TargetProperty="Opacity" From="0.2" To="1" Duration="0:0:0.25" AutoReverse="True" BeginTime="0:0:0.30" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </StackPanel.Triggers>
                        </StackPanel>
                    </Border>
        </Grid>
    </Grid>
</Window>